<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.importer.mapper.ImportJobConfigMapper">

    <resultMap id="ImportJobConfigMap" type="com.example.importer.domain.ImportJobConfig">
        <id property="id" column="id"/>
        <result property="jobCode" column="job_code"/>
        <result property="jobName" column="job_name"/>
        <result property="cronExpression" column="cron_expression"/>
        <result property="enabled" column="enabled"/>
        <result property="ossObjectKey" column="oss_object_key"/>
        <result property="fileSuffix" column="file_suffix"/>
        <result property="delimiter" column="delimiter"/>
        <result property="indexName" column="index_name"/>
        <result property="fieldMappings" column="field_mappings"/>
        <result property="handlerType" column="handler_type"/>
        <result property="batchSize" column="batch_size"/>
        <result property="description" column="description"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="findAllEnabled" resultMap="ImportJobConfigMap">
        select * from import_job_config where enabled = 1 order by id asc
    </select>

    <select id="findAll" resultMap="ImportJobConfigMap">
        select * from import_job_config order by id asc
    </select>

    <select id="findByJobCode" resultMap="ImportJobConfigMap">
        select * from import_job_config where job_code = #{jobCode} limit 1
    </select>
</mapper>
